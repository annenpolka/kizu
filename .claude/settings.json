{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "kizu hook-post-tool --agent claude-code",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "kizu hook-stop --agent claude-code",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}